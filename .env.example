# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_IDS=your_admin_telegram_id_here

# Recommended for invoice parsing and bot intelligence
OPENAI_API_KEY=your_openai_or_gemini_key_here
# OR use GEMINI_API_KEY or GROQ_API_KEY instead

# Optional: use webhooks in hosted deployments like Railway
# Set this to your public app URL, e.g. https://your-app.up.railway.app
WEBHOOK_URL=https://your-app.up.railway.app

# NVIDIA / OpenAI-compatible provider
# Keep your existing OPENAI_API_KEY and point it at NVIDIA's OpenAI-compatible endpoint.
# This preserves your key while defaulting AI calls to NVIDIA-compatible models.
# OPENAI_API_KEY=<your_nvidia_api_key>
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# OPENAI_MODEL=nvidia/llama-3.1-70b-instruct
# OPENAI_VISION_MODEL=nvidia/llama-3.2-90b-vision-instruct
# OPENAI_TRANSCRIBE_MODEL=nvidia/whisper-1

# Recommended for invoice settlement persistence
# Use a long random string in production and keep it stable across deploys.
INVOICE_FORWARDING_SECRET=replace-with-a-long-random-string

# Optional invoice settlement fee collection
APP_FEE_RECIPIENT_ADDRESS=0x0AC27C77C56f5176c37aE23BE3a42A130E3a9359
INVOICE_SETTLEMENT_FEE_BPS=100
INVOICE_SETTLEMENT_MIN_FEE_USDC=0.25
INVOICE_SETTLEMENT_MAX_FEE_USDC=2
INVOICE_SETTLEMENT_CONTRACT_ADDRESS=0x6d7Ae683Bc2dB9a9Cc71Da7da1f5dD510B454ba2

# Optional deployer private key for contract deployment
DEPLOYER_PRIVATE_KEY=6453803f5afafb435cc44806d547c790327f19739d6eba2a817b8c75d845d8d6

# Recommended for Railway/Render/Heroku-style deployments so the SQLite DB survives restarts.
PAYIT_DB_PATH=/app/payit.db
DEPLOYER_PRIVATE_KEY=6453803f5afafb435cc44806d547c790327f19739d6eba2a817b8c75d845d8d6
APP_FEE_RECIPIENT_ADDRESS=0x0AC27C77C56f5176c37aE23BE3a42A130E3a9359
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network